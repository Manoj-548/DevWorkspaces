<parameter name="content">"""
Network Manager for Automated Port Forwarding and Internet Speed Optimization
"""

import os
import sys
import time
import json
import subprocess
import psutil
import netifaces
from datetime import datetime
from typing import Dict, List, Optional, Tuple
from dataclasses import dataclass
from threading import Thread, Event
import logging

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

sys.path.append('/home/manoj/DevWorkspaces')

@dataclass
class NetworkInterface:
    name: str
    ip: str
    gateway: str
    is_up: bool
    speed: Optional[float] = None
    latency: Optional[float] = None
    last_test: Optional[datetime] = None

@dataclass
class SSHTunnel:
    local_port: int
    remote_host: str
    remote_port: int
    ssh_host: str
    ssh_port: int = 22
    process: Optional = None
    status: str = "stopped"

class NetworkManager:
    def __init__(self):
        self.interfaces: Dict[str, NetworkInterface] = {}
        self.tunnels: Dict[int, SSHTunnel] = {}
        self.best_interface: Optional[str] = None
        self.monitoring_active = False
        self.stop_event = Event()
        
        self.services = {
            'django_api': {'port': 8000, 'process': None, 'current_interface': None},
            'realtime_api': {'port': 8765, 'process': None, 'current_interface': None},
            'streamlit': {'port': 8502, 'process': None, 'current_interface': None}
        }
    
    def discover_interfaces(self) -> Dict[str, NetworkInterface]:
        interfaces = {}
        try:
            for iface in psutil.net_if_addrs():
                if iface in ['lo', 'docker0', 'br-']:
                    continue
                
                addrs = psutil.net_if_addrs()[iface]
                ip = None
                gateway = None
                
                for addr in addrs:
                    if addr.family == netifaces.AF_INET:
                        ip = addr.address
                        break
                
                try:
                    gws = netifaces.gateways()
                    if 'default' in gws and iface in gws['default']:
                        gateway = gws['default'][iface][0]
                except:
                    pass
                
                is_up = psutil.net_if_stats().get(iface, None)
                is_up = is_up.isup if is_up else False
                
                interfaces[iface] = NetworkInterface(
                    name=iface,
                    ip=ip or 'N/A',
                    gateway=gateway or 'N/A',
                    is_up=is_up
                )
        except Exception as e:
            logger.error(f"Error discovering interfaces: {e}")
        
        self.interfaces = interfaces
        return interfaces
    
    def test_speed(self, interface_name: str) -> Tuple[Optional[float], Optional[float]]:
        iface = self.interfaces.get(interface_name)
        if not iface or not iface.is_up or iface.ip == 'N/A':
            return None, None
        
        try:
            logger.info(f"Testing speed on {interface_name}...")
            
            # Simple ping test for latency
            latencies = []
            try:
                ping = subprocess.run(
                    ['ping', '-c', '3', '-I', interface_name, '8.8.8.8'],
                    capture_output=True, text=True, timeout=15
                )
                if ping.returncode == 0:
                    for line in ping.stdout.split('\n'):
                        if 'time=' in line:
                            lat = float(line.split('time=')[1].split()[0])
                            latencies.append(lat)
            except:
                pass
            
            latency = sum(latencies) / len(latencies) if latencies else None
            
            # Mock speed for demo (replace with speedtest-cli in production)
            download_speed = 50.0 + (hash(interface_name) % 100)
            
            iface.speed = download_speed
            iface.latency = latency
            iface.last_test = datetime.now()
            
            return download_speed, latency
        except Exception as e:
            logger.error(f"Speed test failed: {e}")
            return None, None
    
    def test_all_interfaces(self) -> Dict[str, Tuple[float, float]]:
        results = {}
        for name, iface in self.interfaces.items():
            if iface.is_up and iface.ip != 'N/A':
                download, latency = self.test_speed(name)
                if download:
                    results[name] = (download, latency)
        return results
    
    def select_best_interface(self) -> Optional[str]:
        if not self.interfaces:
            self.discover_interfaces()
        
        best = None
        best_score = float('-inf')
        
        for name, iface in self.interfaces.items():
            if not iface.is_up or iface.speed is None:
                continue
            
            score = iface.speed
            if iface.latency:
                score += (100 - iface.latency) / 10
            
            if score > best_score:
                best_score = score
                best = name
        
        self.best_interface = best
        logger.info(f"Best interface: {best}")
        return best
    
    def start_monitoring(self, interval: int = 300):
        self.stop_event.clear()
        self.monitoring_active = True
        
        def monitor_loop():
            while not self.stop_event.is_set():
                try:
                    self.test_all_interfaces()
                    self.select_best_interface()
                    self.rebind_services()
                except Exception as e:
                    logger.error(f"Monitoring error: {e}")
                self.stop_event.wait(interval)
        
        self.monitor_thread = Thread(target=monitor_loop, daemon=True)
        self.monitor_thread.start()
        logger.info("Network monitoring started")
    
    def stop_monitoring(self):
        self.stop_event.set()
        self.monitoring_active = False
        logger.info("Network monitoring stopped")
    
    def rebind_services(self):
        if not self.best_interface:
            return
        
        for service_name, config in self.services.items():
            if config['current_interface'] != self.best_interface:
                logger.info(f"Rebinding {service_name} to {self.best_interface}")
                self.restart_service(service_name, self.best_interface)
    
    def restart_service(self, service_name: str, interface: str):
        config = self.services.get(service_name)
        if not config:
            return
        
        if config['process']:
            try:
                config['process'].terminate()
                config['process'].wait(timeout=5)
            except:
                try:
                    config['process'].kill()
                except:
                    pass
        
        iface = self.interfaces.get(interface)
        if not iface:
            return
        
        try:
            if service_name == 'django_api':
                cmd = ['python', 'manage.py', 'runserver', f'{iface.ip}:8000']
                cwd = '/home/manoj/DevWorkspaces/projects/python-dashboard'
            elif service_name == 'realtime_api':
                cmd = ['python', 'main.py']
                cwd = '/home/manoj/DevWorkspaces/services/realtime_api'
            elif service_name == 'streamlit':
                cmd = ['streamlit', 'run', 'app.py', '--server.address', iface.ip, '--server.port', '8502']
                cwd = '/home/manoj/DevWorkspaces/projects/comprehensive-dashboard'
            else:
                return
            
            process = subprocess.Popen(cmd, cwd=cwd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
            config['process'] = process
            config['current_interface'] = interface
            logger.info(f"Started {service_name} on {interface}:{config['port']}")
        except Exception as e:
            logger.error(f"Failed to start {service_name}: {e}")
    
    def create_ssh_tunnel(self, local_port: int, remote_host: str, remote_port: int,
                         ssh_host: str, ssh_port: int = 22) -> bool:
        tunnel = SSHTunnel(
            local_port=local_port,
            remote_host=remote_host,
            remote_port=remote_port,
            ssh_host=ssh_host,
            ssh_port=ssh_port
        )
        
        try:
            cmd = ['ssh', '-N', '-L', f'{local_port}:{remote_host}:{remote_port}', '-p', str(ssh_port), ssh_host]
            process = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
            tunnel.process = process
            tunnel.status = "running"
            self.tunnels[local_port] = tunnel
            logger.info(f"SSH tunnel created: localhost:{local_port} -> {remote_host}:{remote_port}")
            return True
        except Exception as e:
            logger.error(f"Failed to create SSH tunnel: {e}")
            tunnel.status = "failed"
            return False
    
    def close_ssh_tunnel(self, local_port: int) -> bool:
        tunnel = self.tunnels.get(local_port)
        if tunnel and tunnel.process:
            try:
                tunnel.process.terminate()
                tunnel.process.wait(timeout=5)
                tunnel.status = "stopped"
                del self.tunnels[local_port]
                logger.info(f"SSH tunnel closed: {local_port}")
                return True
            except:
                try:
                    tunnel.process.kill()
                    tunnel.status = "stopped"
                    del self.tunnels[local_port]
                    return True
                except:
                    pass
        return False
    
    def get_status(self) -> Dict:
        return {
            'interfaces': {
                name: {
                    'ip': iface.ip,
                    'gateway': iface.gateway,
                    'is_up': iface.is_up,
                    'speed_mbps': iface.speed,
                    'latency_ms': iface.latency,
                    'last_test': iface.last_test.isoformat() if iface.last_test else None
                }
                for name, iface in self.interfaces.items()
            },
            'best_interface': self.best_interface,
            'monitoring_active': self.monitoring_active,
            'tunnels': {
                port: {
                    'local_port': tunnel.local_port,
                    'remote': f"{tunnel.remote_host}:{tunnel.remote_port}",
                    'ssh_host': tunnel.ssh_host,
                    'status': tunnel.status
                }
                for port, tunnel in self.tunnels.items()
            },
            'services': {
                name: {
                    'port': config['port'],
                    'interface': config['current_interface'],
                    'running': config['process'] is not None and config['process'].poll() is None
                }
                for name, config in self.services.items()
            }
        }


network_manager = NetworkManager()

def get_network_status() -> Dict:
    network_manager.discover_interfaces()
    network_manager.select_best_interface()
    return network_manager.get_status()

def test_network_speed(interface: str = None) -> Dict:
    if interface:
        download, latency = network_manager.test_speed(interface)
    else:
        results = network_manager.test_all_interfaces()
        if results:
            best = max(results.items(), key=lambda x: x[1][0])
            download, latency = best[1]
            interface = best[0]
        else:
            download, latency = None, None
            interface = None
    
    return {
        'interface': interface,
        'download_mbps': download,
        'latency_ms': latency,
        'timestamp': datetime.now().isoformat()
    }

def switch_to_best_interface():
    network_manager.start_monitoring()
    return {'status': 'switched', 'interface': network_manager.best_interface}

def create_port_forward(local_port: int, remote_host: str, remote_port: int,
                       ssh_host: str, ssh_port: int = 22) -> Dict:
    success = network_manager.create_ssh_tunnel(local_port, remote_host, remote_port, ssh_host, ssh_port)
    return {'success': success, 'local_port': local_port}

def close_port_forward(local_port: int) -> Dict:
    success = network_manager.close_ssh_tunnel(local_port)
    return {'success': success, 'local_port': local_port}

if __name__ == "__main__":
    print("Discovering interfaces...")
    interfaces = network_manager.discover_interfaces()
    for name, iface in interfaces.items():
        print(f"  {name}: {iface.ip} (up: {iface.is_up})")
    
    print("\nTesting speeds...")
    results = network_manager.test_all_interfaces()
    for name, (speed, latency) in results.items():
        print(f"  {name}: {speed:.2f} Mbps, {latency}ms")
    
    print(f"\nBest interface: {network_manager.select_best_interface()}")
