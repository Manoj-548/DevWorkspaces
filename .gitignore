# ============================================
# DevWorkspaces - Comprehensive .gitignore
# ============================================

# ------------------------------------------------------------------
# OS Generated Files
# ------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# ------------------------------------------------------------------
# IDE and Editor Files
# ------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.c9/
*.launch

# ------------------------------------------------------------------
# Python
# ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ------------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------------
venv*/
env*/
.venv
.venv*/

# ------------------------------------------------------------------
# Logs and Backup Files
# ------------------------------------------------------------------
*.log
logs/
*.swp
*.swo
~
.backup
.bak
*.backup
*.bak

# ------------------------------------------------------------------
# Compressed Archives
# ------------------------------------------------------------------
*.7z
*.tar.gz
*.tar
*.zip
*.gz
*.rar
*.xz

# ------------------------------------------------------------------
# Large Binary Files (Git LFS recommended)
# ------------------------------------------------------------------
*.pt
*.h5
*.hdf5
*.model
*.weights
*.pth
*.ckpt

# ------------------------------------------------------------------
# Database Files
# ------------------------------------------------------------------
*.sqlite
*.db
*.sqlite3
*.db-journal

# ------------------------------------------------------------------
# Cache and Temp Files
# ------------------------------------------------------------------
.cache/
.pytest_cache/
.coverage
htmlcov/
*.cover
.mypy_cache/
*.pyc
__pycache__/
.ruff_cache/

# ------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------
.docker/
docker-compose.override.yml

# ------------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------------
.env
.env.local
.env.*.local
*.local

# ------------------------------------------------------------------
# OS Specific
# ------------------------------------------------------------------
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*.swp
*.swo

# ------------------------------------------------------------------
# Development Specific
# ------------------------------------------------------------------
*.tmp
temp/
temporary/
*.tmp
*.temp

# ------------------------------------------------------------------
# Node.js
# ------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------
# PyTorch Models (if not using LFS)
# ------------------------------------------------------------------
runs/
models/
outputs/

# ------------------------------------------------------------------
# Backup Directories
# ------------------------------------------------------------------
backups/
old/
archive/
legacy/

# ------------------------------------------------------------------
# Windows Paths (should not be in repo)
# ------------------------------------------------------------------
"C:\Users\Acer\"
"C:/Users/Acer/"

# ------------------------------------------------------------------
# Malformed paths
# ------------------------------------------------------------------
"<parameter name="path">"

