#!/usr/bin/env python3
"""Start all background workers for real-time dashboard"""

import asyncio
import sys
import os
import signal
from datetime import datetime

# Add parent directory to path
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from services.config import WORKER_INTERVALS
from services.database import db
from services.workers.system_monitor import system_monitor
from services.workers.github_sync import github_sync_worker
from services.workers.log_aggregator import log_aggregator

logger = None


def setup_logging():
    """Setup logging"""
    global logger
    import logging
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    )
    logger = logging.getLogger("workers")


async def start_workers():
    """Start all background workers"""
    print(f"[{datetime.now().isoformat()}] Starting all workers...")
    
    # Initialize database
    print("Initializing database...")
    await db.connect()
    
    # Start workers
    print(f"Starting system monitor (interval: {WORKER_INTERVALS['system_monitor']}s)...")
    await system_monitor.start()
    
    print(f"Starting GitHub sync (interval: {WORKER_INTERVALS['github_sync']}s)...")
    await github_sync_worker.start()
    
    print(f"Starting log aggregator (interval: {WORKER_INTERVALS['log_aggregator']}s)...")
    await log_aggregator.start()
    
    print("\n" + "="*50)
    print("All workers started successfully!")
    print("="*50)
    print("\nWorker Status:")
    print(f"  - System Monitor: {'Running' if system_monitor.running else 'Stopped'}")
    print(f"  - GitHub Sync: {'Running' if github_sync_worker.running else 'Stopped'}")
    print(f"  - Log Aggregator: {'Running' if log_aggregator.running else 'Stopped'}")
    print("\nPress Ctrl+C to stop all workers\n")


async def stop_workers():
    """Stop all workers"""
    print(f"\n[{datetime.now().isoformat()}] Stopping all workers...")
    
    await system_monitor.stop()
    await github_sync_worker.stop()
    await log_aggregator.stop()
    await db.close()
    
    print("All workers stopped.")


def signal_handler(sig, frame):
    """Handle shutdown signals"""
    print("\nReceived shutdown signal...")
    asyncio.create_task(stop_workers())
    sys.exit(0)


async def main():
    """Main entry point"""
    setup_logging()
    
    # Setup signal handlers
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)
    
    try:
        await start_workers()
        
        # Keep running
        while True:
            await asyncio.sleep(1)
    
    except KeyboardInterrupt:
        await stop_workers()
    except Exception as e:
        logger.error(f"Worker error: {e}")
        await stop_workers()
        raise


if __name__ == "__main__":
    asyncio.run(main())
