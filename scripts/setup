#!/bin/bash
# Branch Protection Setup Script
# This script configures branch protection rules for the DevWorkspaces repository
# Requires GitHub CLI: https://cli.github.com/

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${GREEN}🔒 Setting up Branch Protection for DevWorkspaces${NC}"
echo ""

# Check if GitHub CLI is installed
if ! command -v gh &> /dev/null; then
    echo -e "${RED}❌ GitHub CLI is not installed${NC}"
    echo -e "${YELLOW}Please install it first:${NC}"
    echo "  Ubuntu/Debian: sudo apt install gh"
    echo "  macOS: brew install gh"
    echo "  Windows: scoop install gh"
    exit 1
fi

# Check if authenticated
if ! gh auth status &> /dev/null; then
    echo -e "${YELLOW}⚠️  Not authenticated with GitHub CLI${NC}"
    echo "Please run: gh auth login"
    exit 1
fi

# Get repository info
REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "owner/repo")
echo -e "${GREEN}Repository: ${REPO}${NC}"
echo ""

# Confirm before proceeding
read -p "Apply branch protection rules to main branch? (y/n): " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Cancelled."
    exit 0
fi

echo -e "${GREEN}Applying branch protection rules...${NC}"
echo ""

# Note: Branch protection rules must be set via GitHub UI
# This script provides the configuration details

echo -e "${YELLOW}📋 Branch Protection Configuration:${NC}"
echo ""
echo "The following rules should be configured at:"
echo "  https://github.com/${REPO}/settings/branches"
echo ""
echo "1. ✅ Require pull request reviews before merging"
echo "   - Required approving reviews: 1"
echo "   - Dismiss stale reviews: Yes"
echo ""
echo "2. ✅ Require status checks to pass before merging"
echo "   - Required checks:"
echo "     • lint"
echo "     • test-yolov8"
echo "     • test-django"
echo "     • test-streamlit"
echo ""
echo "3. ✅ Require conversation resolution before merging"
echo ""
echo "4. ✅ Require signed commits (optional)"
echo ""
echo "5. ✅ Require linear history"
echo "   - Allow squash merging: Yes"
echo "   - Allow rebase merging: No"
echo ""
echo "6. ✅ Include administrators"
echo "   - Allow administrators to bypass: No"
echo ""
echo "7. ✅ Restrict who can push to main"
echo "   - Include administrators: Yes"
echo ""

# Create protection via API (if supported)
echo -e "${GREEN}Attempting to configure via GitHub API...${NC}"

# Check if repo is owned by user (personal repo)
OWNER=$(gh repo view --json owner -q .owner.login 2>/dev/null)
USER=$(gh api user -q .login 2>/dev/null)

if [ "$OWNER" = "$USER" ]; then
    echo -e "${YELLOW}Personal repository detected. Applying rules via API...${NC}"
    
    # Note: Some branch protection features require GitHub Enterprise
    # This will apply basic protection
    gh api repos/$REPO/branches/main/protection \
        --method PUT \
        --header "Accept: application/vnd.github.v3+json" \
        --field "required_status_checks={}" \
        --field "enforce_admins=true" \
        --field "required_pull_request_reviews={}" \
        --field "restrictions=null" \
        2>/dev/null || echo -e "${YELLOW}Note: Full branch protection requires GitHub Enterprise or manual setup${NC}"
else
    echo -e "${YELLOW}Organization repository detected.${NC}"
    echo "Branch protection must be configured manually by repository admins."
fi

echo ""
echo -e "${GREEN}✅ Branch protection setup guide complete!${NC}"
echo ""
echo "Next steps:"
echo "1. Go to https://github.com/${REPO}/settings/branches"
echo "2. Click 'Add rule' for 'main' branch"
echo "3. Apply the settings listed above"
echo "4. Click 'Save changes'"
